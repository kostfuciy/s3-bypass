<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 1. HOME TAB -->
        <ScrollView
            android:id="@+id/layout_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Background glow -->
                <View
                    android:id="@+id/glowView"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/glow_circle"
                    app:layout_constraintTop_toTopOf="@id/btnPower"
                    app:layout_constraintBottom_toBottomOf="@id/btnPower"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:alpha="0.07" />

                <!-- App title -->
                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S3"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:letterSpacing="0.4"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BYPASS"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:letterSpacing="0.6"
                    android:fontFamily="sans-serif-light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAppName"
                    android:layout_marginTop="2dp" />

                <!-- Main power button -->
                <com.darkbit.bypass.PowerButton
                    android:id="@+id/btnPower"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
                    app:layout_constraintBottom_toTopOf="@id/tvStatus"
                    app:layout_constraintVertical_bias="0.45"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ОТКЛЮЧЕНО"
                    android:textColor="@color/status_disconnected"
                    android:textSize="15sp"
                    android:letterSpacing="0.25"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvTimer"
                    android:layout_marginBottom="8dp" />

                <!-- Connection timer -->
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/speedSection"
                    android:layout_marginBottom="20dp" />

                <!-- Speed section -->
                <LinearLayout
                    android:id="@+id/speedSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:paddingHorizontal="28dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/configSection"
                    android:layout_marginBottom="20dp">

                    <!-- Download speed card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/speed_card_download"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginEnd="6dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_down"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvDownloadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B/s"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/tvDownloadLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Скачивание"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Upload speed card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/speed_card_upload"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginStart="6dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_up"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvUploadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B/s"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:id="@+id/tvUploadLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Загрузка"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Active Config -->
                <TextView
                    android:id="@+id/tvConfigName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет конфига"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:fontFamily="sans-serif"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="32dp"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>

        <!-- 2. PROFILES TAB -->
        <ScrollView
            android:id="@+id/layout_profiles"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ваши Профили"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:id="@+id/layoutProfilesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/btnImportConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Импорт конфига (.json)"
                    android:textColor="@color/bg_primary"
                    android:backgroundTint="@color/accent_cyan"
                    android:layout_marginTop="24dp"/>

            </LinearLayout>
        </ScrollView>

        <!-- 3. LOGS TAB -->
        <LinearLayout
            android:id="@+id/layout_logs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Журнал событий"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/rgLogFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">
                
                <RadioButton
                    android:id="@+id/rbLogAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Все"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/accent_cyan"
                    android:checked="true"/>
                
                <RadioButton
                    android:id="@+id/rbLogError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ошибки"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/status_disconnected"
                    android:layout_marginStart="16dp"/>
            </RadioGroup>

            <!-- Buttons for Clear / Copy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">
                
                <Button
                    android:id="@+id/btnLogClear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Очистить"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                
                <Button
                    android:id="@+id/btnLogCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Копировать"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollLogs"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#121212"
                android:padding="12dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:fillViewport="true">
                
                <TextView
                    android:id="@+id/tvLogContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Загрузка логов..."
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </ScrollView>
        </LinearLayout>

        <!-- 3. ABOUT TAB -->
        <ScrollView
            android:id="@+id/layout_about"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="32dp">
                
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:layout_marginTop="40dp"
                    app:tint="@color/accent_cyan" />

                <TextView
                    android:id="@+id/tvAboutAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S3 BYPASS"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Версия 1.0"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:id="@+id/btnTelegramChannel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tg_link_bg"
                    android:paddingVertical="16dp"
                    android:layout_marginTop="48dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_telegram"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Официальный канал"
                        android:textColor="@color/accent_cyan"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnTelegramBot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tg_link_bg"
                    android:paddingVertical="16dp"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_telegram"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Бот с профилями"
                        android:textColor="@color/accent_cyan"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Bottom Navigation with floating pill style -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu"
        android:background="@drawable/bg_bottom_nav"
        app:itemBackground="@drawable/bg_bottom_nav_item"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemRippleColor="@null"
        app:labelVisibilityMode="labeled"
        android:layout_margin="16dp"
        android:paddingVertical="8dp"
        android:paddingHorizontal="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
