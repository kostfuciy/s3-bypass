<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:scrollbars="none"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Background glow (subtle, smaller) -->
        <View
            android:id="@+id/glowView"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/glow_circle"
            app:layout_constraintTop_toTopOf="@id/btnPower"
            app:layout_constraintBottom_toBottomOf="@id/btnPower"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:alpha="0.07" />

        <!-- App title -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S3"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:letterSpacing="0.4"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="48dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BYPASS"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:letterSpacing="0.6"
            android:fontFamily="sans-serif-light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAppName"
            android:layout_marginTop="2dp" />

        <!-- Main power button -->
        <com.darkbit.bypass.PowerButton
            android:id="@+id/btnPower"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintBottom_toTopOf="@id/tvStatus"
            app:layout_constraintVertical_bias="0.45"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:layout_goneMarginBottom="48dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ОТКЛЮЧЕНО"
            android:textColor="@color/status_disconnected"
            android:textSize="15sp"
            android:letterSpacing="0.25"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvTimer"
            android:layout_marginBottom="8dp"
            app:layout_goneMarginBottom="36dp" />

        <!-- Connection timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/speedSection"
            android:layout_marginBottom="20dp" />

        <!-- Speed section -->
        <LinearLayout
            android:id="@+id/speedSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingHorizontal="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/configSection"
            android:layout_marginBottom="20dp">

            <!-- Download speed card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/speed_card_download"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_down"
                    android:contentDescription="Download"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvDownloadSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvDownloadLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Скачивание"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Upload speed card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/speed_card_upload"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_up"
                    android:contentDescription="Upload"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvUploadSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvUploadLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Загрузка"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Config section (pinned to bottom) -->
        <LinearLayout
            android:id="@+id/configSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/config_bg"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvConfigName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Нет конфига"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tvImportConfig"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПРОФИЛИ"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Telegram Links Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <!-- Channel Button -->
                <LinearLayout
                    android:id="@+id/btnTelegramChannel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tg_link_bg"
                    android:paddingVertical="12dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_telegram"
                        android:layout_marginEnd="8dp"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Канал"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Bot Button -->
                <LinearLayout
                    android:id="@+id/btnTelegramBot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tg_link_bg"
                    android:paddingVertical="12dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_telegram"
                        android:layout_marginEnd="8dp"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Бот с конфигами"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

            <!-- App Version -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Версия 1.0"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.1" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
